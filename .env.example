# Model keys
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Chat provider: gemini | openai
CHAT_PROVIDER=gemini
CHAT_MODEL=gemini-3-flash-preview
ENFORCE_CITATION_GUARD=false
CHAT_DEBUG=false
# Embedding targets (simple primary/fallback config)
# Providers: ollama | openai | google | openai_compatible | nomic
EMBED_PRIMARY_PROVIDER=ollama
EMBED_PRIMARY_MODEL=nomic-embed-text
EMBED_PRIMARY_BASE_URL=http://127.0.0.1:11434
EMBED_PRIMARY_API_KEY=

EMBED_FALLBACK_PROVIDER=ollama
EMBED_FALLBACK_MODEL=nomic-embed-text
EMBED_FALLBACK_BASE_URL=
EMBED_FALLBACK_API_KEY=
EMBED_FALLBACK_ON_ANY_ERROR=false
# Nomic-specific options (provider=nomic)
NOMIC_TASK_TYPE=search_document
NOMIC_DIMENSIONALITY=
GOOGLE_EMBED_MIN_INTERVAL_MS=700
GOOGLE_EMBED_MAX_ATTEMPTS=6
REEMBED_BATCH_SIZE=100
REEMBED_STATE_PATH=./data/reembed-state.json

# Local SQLite path
SQLITE_PATH=./data/app.db

# Optional: comma-separated state/county policy URLs for ingestion
WEB_SOURCES=https://example.utah.gov/doc1,https://example.county.gov/doc2

# Optional: YouTube MCP ingestion
YOUTUBE_CHANNEL_URL=https://www.youtube.com/@fruitheightscity9716
YOUTUBE_INGEST_START_YEAR=2019
YOUTUBE_YTDLP_PATH=yt-dlp
YOUTUBE_YTDLP_TIMEOUT_MS=120000
YOUTUBE_YTDLP_SOCKET_TIMEOUT_SEC=20
YOUTUBE_YTDLP_RETRIES=1
YOUTUBE_SKIP_VIDEO_IDS=
YOUTUBE_RESUME=true
YOUTUBE_DEFER_EMBED=false
YOUTUBE_CHUNK_SIZE=2400
YOUTUBE_CHUNK_OVERLAP=120
YOUTUBE_MIN_CHUNK_CHARS=240
YOUTUBE_FALLBACK_TRANSCRIBE=false
YOUTUBE_FALLBACK_MODEL=whisper-1
YOUTUBE_INGEST_REPORT_PATH=./data/youtube-ingest-report.json
PENDING_EMBED_BATCH_SIZE=50
PENDING_EMBED_STATE_PATH=./data/pending-embed-state.json

# Optional: YouTube MCP ingestion (advanced/agentic mode)
YOUTUBE_MCP_COMMAND=
YOUTUBE_MCP_ARGS=
YOUTUBE_MCP_SEARCH_TOOL=
YOUTUBE_MCP_TRANSCRIPT_TOOL=
YOUTUBE_MCP_VIDEO_INFO_TOOL=
YOUTUBE_MCP_SEARCH_QUERY_ARG=query
YOUTUBE_MCP_SEARCH_CHANNEL_ARG=channelUrl
YOUTUBE_MCP_TRANSCRIPT_VIDEO_ID_ARG=videoId
YOUTUBE_MCP_TRANSCRIPT_URL_ARG=url
YOUTUBE_MCP_QUERIES=Fruit Heights City Council,Fruit Heights Planning Commission,Fruit Heights General Plan
YOUTUBE_VIDEO_IDS=
YOUTUBE_VIDEO_IDS_FILE=./data/youtube-video-ids.txt
YOUTUBE_MCP_TIMEOUT_MS=45000
YOUTUBE_MCP_MAX_ATTEMPTS=2

# Optional: enrich PDF pages with Gemini vision extraction (maps/charts/images)
PDF_VISION_ENRICH=false
PDF_VISION_MODEL=gemini-3-flash-preview
PDF_INGEST_START_PAGE=1
